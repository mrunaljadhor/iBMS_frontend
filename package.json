{
  "name": "ibms-frontend",
  "version": "1.0.0",
  "description": "Intelligent Battery Management System - Next.js Dashboard",
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:3001": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "start:prod": "next start -p 3001",
    "lint": "next lint",
    "persist:setup": "npm run build && npx pm2 start ecosystem.config.cjs --env production && npx pm2 save",
    "persist:status": "npx pm2 status",
    "persist:logs": "npx pm2 logs trinity-dashboard",
    "persist:stop": "npx pm2 stop trinity-dashboard",
    "persist:restart": "npx pm2 restart trinity-dashboard",
    "persist:delete": "npx pm2 delete trinity-dashboard"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "next": "^14.0.0",
    "@react-google-maps/api": "^2.19.2",
    "axios": "^1.6.2",
    "recharts": "^2.10.3",
    "tailwindcss": "^3.3.6",
    "postcss": "^8.4.31",
    "autoprefixer": "^10.4.16"
  },
  "devDependencies": {
    "eslint": "^8.52.0",
    "eslint-config-next": "^14.0.0",
    "pm2": "^5.4.3"
  }
}
